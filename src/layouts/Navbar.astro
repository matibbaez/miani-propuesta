---
const links = [
  { name: "Inicio", href: "#inicio" },
  { name: "El Estudio", href: "#estudio" },
  { name: "Jurídico", href: "#juridico" },
  { name: "Seguros", href: "#seguros" },
];
---

<header id="main-header" class="fixed top-0 w-full z-50 transition-all duration-500 border-b border-transparent bg-transparent py-4">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between transition-all duration-500" id="header-container">
    
    <a href="#inicio" class="text-white font-serif text-2xl tracking-wide relative group flex items-center gap-1">
      Miani <span class="text-accent text-3xl leading-none font-light group-hover:rotate-12 transition-transform duration-300">&</span> Galceran
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a href={link.href} class="nav-link text-[13px] font-bold text-slate-300 hover:text-white transition-colors uppercase tracking-[0.15em] relative py-2">
          {link.name}
          <span class="absolute bottom-0 left-0 w-0 h-[1px] bg-accent transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
      <a href="#contacto" class="group relative px-6 py-3 bg-accent text-primary font-bold text-xs uppercase tracking-widest rounded-sm overflow-hidden transition-all hover:bg-white hover:shadow-[0_0_15px_rgba(197,160,89,0.3)]">
        <span class="relative z-10">Contacto</span>
        <div class="absolute inset-0 h-full w-full scale-0 rounded-sm transition-all duration-300 group-hover:scale-100 group-hover:bg-white/10"></div>
      </a>
    </nav>

    <button id="menu-toggle" class="md:hidden z-50 focus:outline-none w-12 h-12 flex flex-col justify-center items-center gap-[6px] group" aria-label="Menu">
      <span class="line line-1 w-7 h-[2px] bg-white transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)] origin-center"></span>
      <span class="line line-2 w-7 h-[2px] bg-white transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)]"></span>
      <span class="line line-3 w-7 h-[2px] bg-white transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)] origin-center"></span>
    </button>
  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-primary/98 backdrop-blur-xl z-40 flex flex-col items-center justify-center translate-x-full transition-transform duration-700 cubic-bezier(0.7,0,0.3,1) md:hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-accent to-transparent pointer-events-none"></div>
    
    <nav class="flex flex-col gap-6 text-center relative z-10">
      {links.map((link, index) => (
        // Agregamos un delay escalonado basado en el índice
        <a href={link.href} class="mobile-link text-4xl font-serif text-white/80 hover:text-accent transition-all duration-300 opacity-0 translate-y-4" style={`transition-delay: ${index * 100}ms`}>
          {link.name}
        </a>
      ))}
      <a href="#contacto" class="mobile-link mt-8 px-10 py-4 border border-accent text-accent font-bold uppercase tracking-widest text-sm rounded-sm hover:bg-accent hover:text-primary transition-colors opacity-0 translate-y-4" style={`transition-delay: ${links.length * 100 + 100}ms`}>
        Solicitar Consulta
      </a>
    </nav>
  </div>
</header>

<style>
  /* Animación del Hamburger a Cruz Suave */
  #menu-toggle.is-active .line-1 {
    transform: translateY(8px) rotate(45deg);
    background-color: var(--color-accent);
  }
  #menu-toggle.is-active .line-2 {
    opacity: 0;
    transform: translateX(-20px); /* Se va más lejos */
  }
  #menu-toggle.is-active .line-3 {
    transform: translateY(-8px) rotate(-45deg);
    background-color: var(--color-accent);
  }

  /* Animación de entrada de los links móviles */
  #mobile-menu.is-open .mobile-link {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-link');
  const header = document.getElementById('main-header');
  const headerContainer = document.getElementById('header-container');

  // --- Lógica del Menú Móvil ---
  function toggleMenu() {
    const isOpen = menu.classList.contains('translate-x-full');
    
    btn.classList.toggle('is-active');
    menu.classList.toggle('translate-x-full');
    menu.classList.toggle('is-open'); // Para disparar las animaciones CSS
    
    // Bloquear scroll
    document.body.style.overflow = isOpen ? 'hidden' : 'auto';
  }

  if (btn && menu) {
    btn.addEventListener('click', toggleMenu);

    // Cerrar al hacer click en un link
    links.forEach(link => {
      link.addEventListener('click', () => {
        if (!menu.classList.contains('translate-x-full')) {
           toggleMenu();
        }
      });
    });
  }

  // --- Lógica del Header Dinámico al Scrollear ---
  function updateHeaderState() {
    if (!header) return;
    
    // Si bajamos más de 20px...
    if (window.scrollY > 20) {
      header.classList.remove('bg-transparent', 'border-transparent', 'py-4');
      // Añadimos fondo oscuro, borroso, borde sutil y reducimos el padding
      header.classList.add('bg-primary/90', 'backdrop-blur-md', 'border-white/5', 'shadow-sm', 'py-2');
    } else {
      // Si estamos arriba de todo, volvemos a transparente
      header.classList.add('bg-transparent', 'border-transparent', 'py-4');
      header.classList.remove('bg-primary/90', 'backdrop-blur-md', 'border-white/5', 'shadow-sm', 'py-2');
    }
  }

  window.addEventListener('scroll', updateHeaderState);
  // Ejecutar al cargar por si se recarga la página ya scrolleada
  document.addEventListener('DOMContentLoaded', updateHeaderState);
</script>