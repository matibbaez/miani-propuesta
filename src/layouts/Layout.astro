---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Estudio Jurídico Miani & Galceran - Derecho Civil, Laboral y Seguros." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Manrope:wght@300;400;500;700&display=swap" rel="stylesheet">

    <script is:inline src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>

    <script is:inline>
      // 1. Inicializar Lenis
      const lenis = new Lenis({
        duration: 1.5, // Un poco más lento para que se sienta más "pesado" y premium
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // 2. Interceptar TODOS los clics en enlaces con # (Anclas)
      document.addEventListener('click', (e) => {
        // Buscamos si el elemento clickeado (o su padre) es un enlace <a>
        const link = e.target.closest('a');
        
        // Si es un enlace y tiene un href que empieza con #
        if (link && link.getAttribute('href')?.startsWith('#')) {
          const href = link.getAttribute('href');
          
          // Evitamos el salto brusco predeterminado del navegador
          if (href.length > 1) { // Ignorar enlaces que son solo "#"
            e.preventDefault();
            
            // Usamos Lenis para bajar suavemente
            lenis.scrollTo(href, {
              offset: 0, // Ajuste si el título queda muy pegado arriba (puedes poner -50 si el header tapa)
              duration: 2.0, // Duración personalizada para el clic (más suave aún)
              easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            });
          }
        }
      });

      // 3. Observer para animaciones "Reveal" al hacer scroll
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      // Esperar a que cargue el DOM para buscar elementos .reveal
      document.addEventListener('DOMContentLoaded', () => {
        const revealElements = document.querySelectorAll('.reveal');
        revealElements.forEach(el => observer.observe(el));
      });
    </script>

    <title>{title} | Miani & Galceran</title>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>